<div id="<%= dom_id(cart_item) %>" class="flex items-center gap-4 py-4 border-b">
  
  
  <div class="flex-grow">
    <h3 class="font-semibold"><%= cart_item.product_name %></h3>
    
    <div class="flex items-center gap-4 mt-2">
      <%= form_with model: cart_item, local: false do |f| %>
        <div class="flex items-center gap-2">
          <%= button_tag "-", 
              type: "submit",
              name: "cart_item[quantity]",
              value: cart_item.quantity - 1,
              class: "px-2 py-1 border rounded hover:bg-gray-50" %>
              
          <span class="w-8 text-center">
            <%= cart_item.quantity %>
          </span>
          
          <%= button_tag "+", 
              type: "submit",
              name: "cart_item[quantity]",
              value: cart_item.quantity + 1,
              class: "px-2 py-1 border rounded hover:bg-gray-50" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="text-right">
    <div class="font-semibold">
      <%= number_to_currency(cart_item.subtotal) %>
    </div>
    
    <%= button_to cart_item_path(cart_item),
        method: :delete,
        class: "text-gray-400 hover:text-gray-600 mt-2" do %>
      <svg xmlns="http://www.w3.org/2000/svg" 
           fill="none" 
           viewBox="0 0 24 24" 
           stroke-width="1.5" 
           stroke="currentColor" 
           class="w-5 h-5">
        <path stroke-linecap="round" 
              stroke-linejoin="round" 
              d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
      </svg>
    <% end %>
  </div>
</div>