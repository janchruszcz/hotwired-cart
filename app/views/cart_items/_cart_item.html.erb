<div id="<%= dom_id(cart_item) %>" class="flex items-center gap-4 py-4 border-b">
  <%= image_tag "", class: "h-24 w-24 object-cover" %>
  
  <div class="flex-grow">
    <h3 class="font-semibold"><%= cart_item.product.name %></h3>
    
    <div class="flex items-center gap-4 mt-2">
      <%= form_with model: cart_item, local: false do |f| %>
        <div class="flex items-center gap-2">
          <%= button_tag "-", type: "submit", 
              name: "cart_item[quantity]", 
              value: cart_item.quantity - 1,
              class: "px-2 py-1 border rounded" %>
              
          <span class="w-8 text-center"><%= cart_item.quantity %></span>
          
          <%= button_tag "+", type: "submit", 
              name: "cart_item[quantity]", 
              value: cart_item.quantity + 1,
              class: "px-2 py-1 border rounded" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="text-right">
    <div class="font-semibold">
      <%= number_to_currency(cart_item.subtotal) %>
    </div>
    
    <%= button_to cart_item_path(cart_item), 
        method: :delete,
        class: "text-gray-400 hover:text-gray-600" do %>
      <i class="fas fa-trash"></i>
    <% end %>
  </div>
</div>